{
  "name": "localjudge",
  "displayName": "localjudge",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:localjudge-ui.openUI",
    "onCommand:localjudge.login",
    "onCommand:localjudge.run",
    "onCommand:localjudge.refreshLanguages"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "localjudge.login", "title": "LocalJudge: Login (Set Token)" },
      { "command": "localjudge.run", "title": "LocalJudge: Run (Judge)" },
      { "command": "localjudge.refreshLanguages", "title": "LocalJudge: Refresh Languages" },
      { "command": "localjudge-ui.openUI", "title": "LocalJudge: Open UI" }
    ],
    "configuration": {
      "title": "LocalJudge",
      "properties": {
        "localjudge.baseUrl": {
          "type": "string",
          "default": "https://pslab.squidspirit.com",
          "description": "Backend API base URL"
        },
        "localjudge.wait": {
          "type": "boolean",
          "default": true,
          "description": "Use wait=true for /code-judge/judge"
        },
        "localjudge.pollIntervalMs": {
          "type": "number",
          "default": 1000,
          "description": "Polling interval when wait=false"
        },
        "localjudge.pollTimeoutMs": {
          "type": "number",
          "default": 30000,
          "description": "Polling timeout when wait=false"
        },
        "localjudge.dryRun": {
          "type": "boolean",
          "default": false,
          "description": "If true, do not call backend. Only print what would be sent."
        },
        "localjudge.previewChars": {
          "type": "number",
          "default": 800,
          "description": "How many characters of source_code to preview in Output."
        },
        "localjudge.stdinDefault": {
          "type": "string",
          "default": "",
          "description": "Default stdin shown when running a submission."
        },
        "localjudge.token": {
          "type": "string",
          "default": "",
          "description": "Access token (stored in settings; prefer the Login command which saves it securely)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.107.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.48.1",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "axios-cookiejar-support": "^6.0.5",
    "tough-cookie": "^6.0.0"
  }
}
