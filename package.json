{
  "name": "localjudge-ui",
  "publisher": "anna",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.107.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:localjudge-ui.openUI",
    "onUri"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "localjudge-ui.openUI",
        "title": "LocalJudge: Open UI"
      },
      {
        "command": "localjudge.testLogin",
        "title": "LocalJudge: Test Login"
      }
    ],
    "configuration": {
      "title": "LocalJudge",
      "properties": {
        "localjudge.baseUrl": {
          "type": "string",
        "default": "",
        "description": "Base URL of LocalJudge server (e.g. https://pslab.squidspirit.com)"
        }
      }
    },
    "uriHandler": {
      "schemes": ["vscode"]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.107.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.48.1",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
